# Environment files - NEVER commit these
.env
.env.local
.env.*.local
backend/.env

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.venv/
venv/
env/

# Node / Frontend
node_modules/
app/node_modules/
app/dist/
app/.vite/
*.log
npm-debug.log*

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.vscode/
.idea/
*.swp
*.swo

# Tooling scratch / caches
.ruff_cache/
.claude/worktrees/
.branch-review/
.claude-flow/
.hive-mind/
.playwright-mcp/

# Local DB + backups (dev SQLite is auto-created from models)
backend/*.db
backend/*.db.bak*
backend/*.db-journal

# Python lockfiles (pip/uv) — backend uses requirements.txt as source of truth
backend/uv.lock

# Verification / smoke-test scratch
smoke-*.png
verification-*.png

# Playwright E2E
app/test-results/
app/playwright-report/
e2e.db
backend/e2e.db

# Note: Playwright snapshot baselines (app/e2e/**/*-snapshots/) ARE committed to repo.
# They serve as canonical reference images for visual regression tests.
# app/e2e/**/*-snapshots/ is NOT ignored and should be tracked by git.
