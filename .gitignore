# Environment files - NEVER commit these
.env
.env.local
.env.*.local
backend/.env

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.venv/
venv/
env/

# Node / Frontend
node_modules/
app/node_modules/
app/dist/
app/.vite/
*.log
npm-debug.log*

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.vscode/
.idea/
*.swp
*.swo

# Tooling scratch / caches
.ruff_cache/
.claude/worktrees/
.branch-review/
