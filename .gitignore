# Environment files - NEVER commit these
.env
.env.local
.env.*.local
backend/.env

# Google credentials / OAuth tokens - NEVER commit these (any location)
**/client_secret*.json
client_secret*.json
**/service_account*.json
service_account*.json
backend/.cal_test_token.json
# Downloaded service-account key files (<project>-<keyid>.json)
aai-ops-calender-sync-*.json

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.venv/
venv/
env/

# Node / Frontend
node_modules/
app/node_modules/
app/dist/
app/.vite/
*.log
npm-debug.log*

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.vscode/
.idea/
*.swp
*.swo

