# Local DB + backups (dev SQLite is auto-created from models)
backend/*.db
backend/*.db.bak*
backend/*.db-journal

# Python lockfiles (pip/uv) — backend uses requirements.txt as source of truth
backend/uv.lock

# Verification / smoke-test scratch
smoke-*.png
verification-*.png

# Playwright generated output
app/playwright-report/
app/test-results/

# Local dev-only Docker overrides (e.g. DEV_AUTH_BYPASS for the dev-login button)
docker-compose.override.yml

# Dev-only WorkItemPanel preview harness (not linked from the app)
app/preview.html
app/src/preview.tsx

# Local simplify-audit analysis reports (not part of any PR)
.simplify-audit/
